# ============================================================
# Prajapati Foundation — Environment Variables
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to version control.
# ============================================================

# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Razorpay (get these from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# News auto-refresh (in hours)
NEWS_REFRESH_INTERVAL_HOURS=6

# Set to "False" to disable the background news auto-fetch thread
NEWS_AUTO_REFRESH_ENABLED=True

# ── Media storage (Cloudflare R2) ────────────────────────────────────────
# Set to True once you've created an R2 bucket. When False, uploaded photos
# (gallery, volunteers) are saved to the local media/ folder instead.
USE_R2_STORAGE=False

# From Cloudflare dashboard -> R2 -> Manage API Tokens (create a token with
# "Object Read & Write" permission scoped to your bucket)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=prajapati-foundation-media

# The public URL for your bucket. Easiest option: in the bucket's
# Settings -> Public Access, enable the free "r2.dev" subdomain and paste it
# here WITHOUT https:// (e.g. pub-1234567890abcdef.r2.dev).
# A custom domain works too if you've mapped one.
R2_PUBLIC_URL=pub-xxxxxxxxxxxxxxxx.r2.dev
